    "date-fns": "^2.30.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hook-form": "^7.48.0",
    "react-router-dom": "^6.21.0",
    "recharts": "^2.10.0",
    "workbox-core": "^7.0.0",
